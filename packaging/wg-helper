#!/bin/bash
# wg-helper — the single privileged entry point for wireguard-tui.
#
# The TUI runs as a normal user and invokes:
#     sudo -n  wg-helper <verb> [name]      (sudoers mode)
#     pkexec   wg-helper <verb> [name]      (polkit / fallback mode)
#
# Only this one script is whitelisted, so the privileged surface is exactly the
# verbs below. Every tunnel name is validated against a strict pattern before
# any filesystem or `wg` operation, and every mutating action is logged.
set -euo pipefail

# Run with a known-good PATH. sudo's `secure_path` and pkexec normally reset
# PATH, but not every distro configures secure_path — set it ourselves so a
# hijacked caller PATH can never point us at a malicious `wg`/`logger`/etc.
export PATH="/usr/sbin:/usr/bin:/sbin:/bin"

# Fixed paths — never taken from the (untrusted) caller's environment.
readonly WG_DIR="/etc/wireguard"
readonly BACKUP_DIR="${WG_DIR}/.backup"
readonly LOG_TAG="wireguard-tui"

die() { echo "wg-helper: $*" >&2; exit 2; }

# Audit log to syslog (journald). Records the invoking user when known.
log() {
    local who="${PKEXEC_UID:-}"
    [ -n "${SUDO_USER:-}" ] && who="${SUDO_USER}"
    logger -t "$LOG_TAG" -- "user=${who:-unknown} action=$*" 2>/dev/null || true
}

# A tunnel name must: start alphanumeric, then [A-Za-z0-9_.-], max 15 chars,
# and never be "."/".." or contain "..". With no "/" allowed, the path
# "$WG_DIR/<name>.conf" can never escape the directory.
name_ok() {
    local n="${1:-}"
    [[ "$n" =~ ^[A-Za-z0-9][A-Za-z0-9_.-]{0,14}$ ]] || return 1
    case "$n" in *..*) return 1 ;; esac
    return 0
}
validate_name() {
    name_ok "${1:-}" || die "invalid tunnel name: '${1:-}'"
}

# Not every distro uses systemd (start-on-boot uses `wg-quick@` units).
have_systemctl() { command -v systemctl >/dev/null 2>&1; }

# Bound external wg/wg-quick calls so a hang (DNS, a stuck PostUp, a wedged
# interface, …) can't lock up the caller. `timeout` ships in coreutils on every
# supported distro; if it's somehow missing, fall back to running directly.
T() {
    local secs="$1"; shift
    if command -v timeout >/dev/null 2>&1; then
        timeout "$secs" "$@"
    else
        "$@"
    fi
}

# Copy an existing config to the timestamped backup dir before we touch it.
backup_existing() {
    local n="$1" src="${WG_DIR}/$1.conf"
    [ -f "$src" ] || return 0
    install -d -m 700 "$BACKUP_DIR"
    local ts; ts="$(date +%Y%m%d-%H%M%S)"
    local dst="${BACKUP_DIR}/${n}.conf.${ts}"
    cp -p "$src" "$dst"
    chmod 600 "$dst"
    log "backup ${n} -> ${dst}"
}

verb="${1:-}"
[ -n "$verb" ] || die "no verb"
shift || true

case "$verb" in
    list)
        # Pure-bash glob (BusyBox `find` has no -printf) and filter to names the
        # rest of the helper will accept, so a hand-dropped odd filename can't
        # surface a name we'd later reject.
        [ -d "$WG_DIR" ] || exit 0
        shopt -s nullglob
        for f in "$WG_DIR"/*.conf; do
            n="$(basename "$f" .conf)"
            name_ok "$n" || continue
            printf '%s\n' "$n"
        done | sort
        ;;
    active)
        T 5 wg show interfaces 2>/dev/null || true
        ;;
    read)
        validate_name "${1:-}"
        cat "${WG_DIR}/$1.conf"
        ;;
    dump)
        validate_name "${1:-}"
        T 5 wg show "$1" dump 2>/dev/null || true
        ;;
    up)
        validate_name "${1:-}"
        log "up $1"
        T 45 wg-quick up "$1"
        ;;
    down)
        validate_name "${1:-}"
        log "down $1"
        T 30 wg-quick down "$1"
        ;;
    save)
        # Content from stdin. Back up first, then write atomically (temp + rename)
        # so a crash mid-write can never leave a truncated config.
        validate_name "${1:-}"
        backup_existing "$1"
        umask 077
        tmp="${WG_DIR}/.$1.conf.tmp.$$"
        trap 'rm -f "$tmp" 2>/dev/null || true' EXIT
        cat > "$tmp"
        chmod 600 "$tmp"
        mv -f "$tmp" "${WG_DIR}/$1.conf"
        trap - EXIT
        log "save $1"
        ;;
    delete)
        # Always back up before removing — the GUI's delete button relies on this.
        validate_name "${1:-}"
        backup_existing "$1"
        T 30 wg-quick down "$1" 2>/dev/null || true
        if have_systemctl && systemctl is-enabled "wg-quick@$1" >/dev/null 2>&1; then
            systemctl disable "wg-quick@$1" >/dev/null 2>&1 || true
        fi
        rm -f "${WG_DIR}/$1.conf"
        log "delete $1"
        ;;
    rename)
        validate_name "${1:-}"
        validate_name "${2:-}"
        [ "$1" != "$2" ] || die "source and destination names must differ"
        src="${WG_DIR}/$1.conf"
        dst="${WG_DIR}/$2.conf"
        [ -f "$src" ] || die "no such tunnel: $1"
        [ ! -e "$dst" ] || die "target already exists: $2"
        current="$(T 5 wg show interfaces 2>/dev/null || true)"
        case " $current " in
            *" $1 "*) T 30 wg-quick down "$1" || die "rename requires the active tunnel to stop: $1" ;;
        esac
        backup_existing "$1"
        if have_systemctl && systemctl is-enabled "wg-quick@$1" >/dev/null 2>&1; then
            systemctl disable "wg-quick@$1" >/dev/null 2>&1 || true
            enabled=1
        else
            enabled=0
        fi
        umask 077
        tmp="${WG_DIR}/.$2.conf.tmp.$$"
        trap 'rm -f "$tmp" 2>/dev/null || true' EXIT
        cat > "$tmp"
        chmod 600 "$tmp"
        mv -f "$tmp" "$dst"
        trap - EXIT
        if [ "$enabled" -eq 1 ] && have_systemctl; then
            systemctl enable "wg-quick@$2" >/dev/null 2>&1 || true
        fi
        rm -f "$src"
        log "rename $1 -> $2"
        ;;
    enable)
        validate_name "${1:-}"
        have_systemctl || die "start-on-boot needs systemd (systemctl not found)"
        log "enable $1"
        systemctl enable "wg-quick@$1" >/dev/null 2>&1
        ;;
    disable)
        validate_name "${1:-}"
        have_systemctl || die "start-on-boot needs systemd (systemctl not found)"
        log "disable $1"
        systemctl disable "wg-quick@$1" >/dev/null 2>&1
        ;;
    is-enabled)
        validate_name "${1:-}"
        # On non-systemd systems report "unknown" so the UI just shows "off".
        have_systemctl || { echo "unknown"; exit 0; }
        systemctl is-enabled "wg-quick@$1" 2>/dev/null || true
        ;;
    sync)
        # Apply the on-disk config to the RUNNING interface without dropping
        # peer sessions (wg-level changes only). Capture `strip` and check it
        # first — process substitution would mask a strip failure and feed an
        # empty config to syncconf, wiping every peer off the live interface.
        validate_name "${1:-}"
        log "sync $1"
        stripped="$(T 15 wg-quick strip "$1")" || die "wg-quick strip failed for $1"
        [ -n "$stripped" ] || die "wg-quick strip produced no output for $1"
        printf '%s\n' "$stripped" | T 15 wg syncconf "$1" /dev/stdin
        ;;
    showconf)
        # The live running wg-level config (no Address/DNS/MTU/Table).
        validate_name "${1:-}"
        T 10 wg showconf "$1" 2>/dev/null || true
        ;;
    persist)
        # Save the live running state back to the .conf (wg-quick save).
        validate_name "${1:-}"
        backup_existing "$1"
        log "persist $1"
        T 30 wg-quick save "$1"
        ;;
    log)
        # Recent activity: this app's audit entries + wg-quick service logs.
        if command -v journalctl >/dev/null 2>&1; then
            echo "===== wireguard-tui activity ====="
            journalctl --no-pager -o short-iso -n 300 -t "$LOG_TAG" 2>/dev/null || true
            echo
            echo "===== wg-quick (systemd) ====="
            journalctl --no-pager -o short-iso -n 200 -u 'wg-quick@*' 2>/dev/null || true
        else
            echo "(journalctl is not available on this system — logs are only"
            echo " recorded on systemd installs.)"
        fi
        ;;
    *)
        die "unknown verb: $verb"
        ;;
esac
