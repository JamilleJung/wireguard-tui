/* polkit rule for wireguard-tui.
 *
 * Lets a user who is BOTH in an active local session AND a member of the
 * "wireguard" group run the wg-helper through pkexec without a password. The
 * group requirement is essential: the helper can read /etc/wireguard configs
 * (which contain private keys), so it must NOT be exposed to every active-local
 * user. install.sh (--polkit) and the .deb create the group and add the
 * intended user; until then this rule denies (pkexec falls back to asking for
 * the admin password — fail closed). The sudoers drop-in is the source-install
 * default. Requires polkit with JS rules (>= 0.106).
 */
polkit.addRule(function(action, subject) {
    if (action.id === "org.freedesktop.policykit.exec" &&
        (action.lookup("program") === "/usr/local/lib/wireguard-tui/wg-helper" ||
         action.lookup("program") === "/usr/lib/wireguard-tui/wg-helper") &&
        subject.local && subject.active && subject.isInGroup("wireguard")) {
        return polkit.Result.YES;
    }
});
